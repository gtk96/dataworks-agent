# ============================================================
# dataworks-agent 环境配置
# 复制此文件为 .env 并填入实际值
# ============================================================
#
# ⚠️ 真实凭据安全提示：
# - 永远不要把生产 .env 内容粘贴到任何 LLM 对话窗口、Issue、PR 评论、日志或 wiki。
# - 一旦贴出就视为已泄漏，请到云控制台轮换 AK/SK、LLM Key、Cookie 加密密钥等。
# - 这个文件只能含占位符；真实凭据放在 .env 且必须在 .gitignore 里。
# ============================================================

# 阿里云 AK/SK 鉴权（Auth_Provider 唯一凭证来源，不读 ECS RAM Role / 本地 credentials 文件）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# MaxCompute（pyodps）执行底座
MAXCOMPUTE_ENDPOINT=http://service.cn-shenzhen.maxcompute.aliyun.com/api
MAXCOMPUTE_PROJECT=dataworks

# LLM 服务（OpenAI 兼容网关，provider 无关；api_key 仅置于 .env，绝不入库入 git）
LLM_BASE_URL=https://opencode.ai/zen/v1
LLM_MODEL=deepseek-v4-flash-free
LLM_API_KEY=

# DataWorks 项目配置（请从 DataWorks 控制台 URL / 控制台 settings 获取并填入）
DATAWORKS_PROJECT_ID=
DATAWORKS_DATASOURCE_ID=
DATAWORKS_RESOURCE_GROUP=
DATAWORKS_REGION=cn-shenzhen
DATAWORKS_TENANT_ID=

# Hologres ODS 节点必须落在真实存在的 Hologres 目录树
HOLO_ODS_NODE_PATH=业务流程/100_订单信息/Hologres/数据开发/00_ODS

# 数仓 Schema
DATAWORKS_DEV_SCHEMA=dataworks_dev
DATAWORKS_PROD_SCHEMA=dataworks

# 服务配置
DW_MODELING_PORT=8085
# Slim default: keep L1-L5 semantic/runtime/MCP Server skeleton routes hidden; set true for debugging
ENABLE_EXPERIMENTAL_PLATFORM_ROUTES=false
DW_MODELING_HOST=127.0.0.1
HOST=127.0.0.1
PORT=8085
# 受信反向代理对端 IP（nginx 127.0.0.1 / 10.0.0.1）；逗号分隔多个，空则不信 X-Forwarded-For
TRUSTED_PROXIES=

# IDE 配置
IDE_AGENT_DIR=dataworks_agent
ROOT_CHECK_NODE_UUID=
SMOKE_TEST_NODE_UUID=

# 安全
# Cookie/BFF/CDP 是 AK/SK 元数据权限缺口的长期兜底，不删除
COOKIE_ENCRYPTION_KEY=change-me-to-at-least-16-chars

# Cookie 保活（BFF /csrf 心跳，不重新提取）
COOKIE_KEEPALIVE_ENABLED=true

# Cookie 后台自助刷新（CDP 定时校验 + 失效重提取）
AUTO_LOGIN_ENABLED=true
COOKIE_REFRESH_POLL_SECONDS=600
CDP_URL=http://localhost:9222

# 词根表自动同步（生产 dim_pub_column_dictionary_static → 本地 SQLite，默认每 2 小时）
WORD_ROOT_AUTO_SYNC_ENABLED=true
WORD_ROOT_SYNC_INTERVAL_SECONDS=7200

# 阿里云官方 DataWorks MCP（npm stdio server）；AK/SK 仅注入子进程环境变量
OFFICIAL_DATAWORKS_MCP_ENABLED=true
OFFICIAL_DATAWORKS_MCP_COMMAND=npx
OFFICIAL_DATAWORKS_MCP_PACKAGE=alibabacloud-dataworks-mcp-server@1.0.45
# 可选：进一步收窄工具白名单；留空时使用项目内置精简白名单
OFFICIAL_DATAWORKS_MCP_TOOL_NAMES=

# 自主问数默认返回行数与超时限制
ASK_DATA_DEFAULT_LIMIT=100
ASK_DATA_TIMEOUT_SECONDS=120
