VERSION=0.0.0-dev

# Server
HOST=127.0.0.1
PORT=8084

# Runtime
DATAWORKS_AGENT_ENV=development
DATAWORKS_AGENT_DRY_RUN=1
DATAWORKS_AGENT_MODE=dry-run
DATAWORKS_AGENT_PUBLIC_REGISTRATION=0
DATAWORKS_AGENT_WORKER_IDLE_SECONDS=900
LOG_LEVEL=info

# Default workspace (set to a workspace_id after creation)
DEFAULT_WORKSPACE=

